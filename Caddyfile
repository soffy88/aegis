{
    admin 0.0.0.0:2019
    # Automatic HTTPS (Let's Encrypt) is enabled for host-matched website routes
    # added at runtime via the admin API. The :8080 tunnel entry below has no
    # hostname, so nothing here triggers cert issuance for the console itself
    # (that stays behind the Cloudflare edge).
    email soffy88@gmail.com
}

# Mneme API
:8081 {
    reverse_proxy mneme-api-1:8000
}

# Mneme 前端 + studio + 门控工具面(S3-B 同 host 路径路由,保留前缀不 strip)
:8083 {
    handle /mcp/* {
        reverse_proxy mneme-api-1:8000
    }
    handle /studio* {
        reverse_proxy mneme-studio:3001
    }
    handle {
        reverse_proxy mneme-web:3000
    }
}

# Stratum API
:8084 {
    reverse_proxy stratum-api:9302
}

# Stratum 前端
:8085 {
    reverse_proxy stratum-web:3000
}

# AII (Stratum 子产品)
:8086 {
    reverse_proxy aii-web:3101
}

# Hevi (hevi.kanpan.co 单一 Cloudflare Tunnel public hostname 打到这个端口 —
# 前端用同源 /api/* 调后端，跟 hevi 自己原来独立 tunnel 的路径拆分逻辑保持一致，
# 不能像 stratum/mneme 那样拆成两个端口，否则前端同源 /api/* 请求全落到前端容器)
:8088 {
    handle /api/* {
        reverse_proxy hevi-cftunnel-hevi-api-1:8000
    }
    handle {
        reverse_proxy hevi-cftunnel-hevi-web-1:3000
    }
}

# Selene (sel.kanpan.co 单一 Cloudflare Tunnel public hostname 打到这个端口 —
# 前端 nginx 已同源反代 /api、/ws 到 gateway，跟 hevi 一样单端口即可，不能拆两个端口)
:8089 {
    reverse_proxy selene-frontend-1:80
}

# Stirling-PDF (pdf.sxueji.com — 应用市场装的 app,手动发布。stirling 容器在
# helios-net(已 network connect,原 bridge),caddy 按容器名直连 :8080。
# 后续若改用 aegis 发布功能自动建路由,可移除此块)
:8091 {
    reverse_proxy stirling-pdf:8080
}

# Helivex (helivex.kanpan.co 单一 Cloudflare Tunnel public hostname 打到这个端口 —
# helivex-web 是 host 网络容器直接 bind 宿主 :3400，caddy 经 helios-net 网关 172.18.0.1
# 够到它。Next 前端已同源 /gw 反代到 gateway，单端口即可。Host 透传后 helivex-web
# 按 Host 头判 non-local → DASH_USER/DASH_PASS Basic Auth，跟原独立 tunnel 行为一致)
:8090 {
    reverse_proxy 172.18.0.1:3400
}

# Aegis 主入口
:8080 {
    handle /api/* {
        reverse_proxy aegis-backend:8000 {
            # 后端重启/部署期间短暂排队重试，避免直接 502
            lb_try_duration 5s
            lb_try_interval 250ms
        }
    }
    handle /api/v1/orgs/*/docker/containers/*/terminal {
        reverse_proxy aegis-backend:8000 {
            header_up Connection "Upgrade"
            header_up Upgrade "websocket"
        }
    }
    handle {
        reverse_proxy aegis-console:3000
    }
}
