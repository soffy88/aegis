# Aegis SRE platform Caddyfile (M2-E-Batch-3 修订: Cloudflare Tunnel 模式)
# CF 边缘负责 TLS + HSTS, Caddy 仅内部 HTTP 反代

:8080 {
	# /api/* → backend
	handle /api/* {
		reverse_proxy aegis-backend:8000
	}

	# 其他 → console (Next.js mini server)
	handle {
		reverse_proxy aegis-console:3000
	}

	# 安全 headers (M1 基础, HSTS 由 CF 边缘加)
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Access log
	log {
		output file /var/log/caddy/aegis.uex.hk.log {
			roll_size 100MB
			roll_keep 7
		}
		format json
	}
}

# (未来) 其他项目公网发布同款模式:
# :8081 { reverse_proxy helios-backend:8000 ... }
# Cloudflare Tunnel ingress 配 helios.uex.hk → aegis-caddy:8081
