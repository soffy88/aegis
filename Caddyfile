# Aegis SRE platform Caddyfile
# Aegis 自身公网发布 + (未来) 其他项目公网发布

# Aegis console + API
aegis.uex.hk {
	# /api/* → backend
	handle /api/* {
		reverse_proxy aegis-backend:8000
	}

	# 其他 → console (Next.js mini server)
	handle {
		reverse_proxy aegis-console:3000
	}

	# 自动 HTTPS (Let's Encrypt) — Caddy 默认行为
	# 自动 HTTP → HTTPS redirect

	# 安全 headers (M1 基础)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Access log
	log {
		output file /var/log/caddy/aegis.uex.hk.log {
			roll_size 100MB
			roll_keep 7
		}
		format json
	}
}

# (未来) 其他项目公网发布同款模式:
# helios.uex.hk { reverse_proxy helios-backend:8000 ... }
# helixa.uex.hk { reverse_proxy helixa-backend:8000 ... }
