# Aegis prod stack env vars (复制为 .env.aegis 填真值, .env.aegis 不入 git)

# Database (跟 platform-postgres 共享凭据)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<填 Wiki platform-postgres 真密码>

# Aegis 版本 (docker image tag)
AEGIS_VERSION=latest

# JWT (生产必须强随机, openssl rand -hex 32)
AEGIS_JWT_SECRET=<填 64 字符 hex 随机>

# Aegis 自监控
AEGIS_SENTRY_ENABLED=true
AEGIS_SENTRY_DSN=  # M2-E-Batch-2 ship 后, console UI 创 Aegis 内部 project, psql 查 sentry_public_key, 拼 DSN 后填这里, restart aegis-backend

# LLM provider (可选, 跑 Brain RCA 才需, M1 试用可空)
AEGIS_LLM_PROVIDER=
ANTHROPIC_API_KEY=
