# ============================================================
# Aegis 生产环境配置模板
# 复制为 .env.aegis 填入真值，.env.aegis 不入 git
# ============================================================

# === 版本 ===
AEGIS_VERSION=latest

# === 数据库 (platform-postgres, helios-net) ===
POSTGRES_USER=helios
POSTGRES_PASSWORD=your-postgres-password-here

# === JWT (必填，openssl rand -hex 32 生成) ===
AEGIS_JWT_SECRET=your-32-byte-hex-secret-here

# === CORS ===
AEGIS_CORS_ALLOWED_ORIGINS=https://aegis.uex.hk

# === Cloudflare Tunnel ===
CLOUDFLARED_TOKEN=your-cloudflared-token-here

# === LLM (可选，Brain/RCA 功能需要) ===
AEGIS_LLM_PROVIDER=anthropic
AEGIS_LLM_MODEL_DEFAULT=claude-haiku-4-5
AEGIS_LLM_MODEL_PREMIUM=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Embedding (可选，Runbook RAG 检索需要) ===
# 不填则用 hash-based stub（功能正常但检索质量低）
AEGIS_EMBEDDING_PROVIDER=default
AEGIS_RUNBOOK_VECTOR_DIM=1024

# === AutoHeal ===
AEGIS_AUTOHEAL_ENABLED=true
# 生产建议先设 true 观察，确认插件行为后改 false
AEGIS_AUTOHEAL_DRY_RUN=true

# === Backup / S3 (可选) ===
# 不填则备份到本地 /data/aegis/backups
AEGIS_BACKUP_S3_BUCKET=
AEGIS_BACKUP_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AEGIS_BACKUP_S3_REGION=us-east-1

# === 邮件 (可选，Resend) ===
AEGIS_RESEND_API_KEY=
AEGIS_EMAIL_FROM_ADDR=noreply@aegis.uex.hk

# === 自监控 (可选，Sentry) ===
AEGIS_SENTRY_ENABLED=false
AEGIS_SENTRY_DSN=

# === Agent token (可选，aegis-agent 鉴权) ===
# 不填则 agent 无需 token（仅局域网部署可接受）
AEGIS_AGENT_TOKEN=

# === Console ===
NEXT_PUBLIC_AEGIS_API=https://aegis.uex.hk
